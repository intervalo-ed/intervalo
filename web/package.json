{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run sync:all && next dev",
    "build": "bun run sync:all && next build",
    "start": "next start",
    "lint": "eslint",
    "sync:all": "bun run sync:catalog && bun run sync:emoji-tree && bun run types:api:file",
    "sync:catalog": "bun run scripts/sync-catalog.ts",
    "sync:emoji-tree": "bun run scripts/sync-emoji-tree.ts",
    "types:api": "openapi-typescript http://127.0.0.1:8000/openapi.json -o src/lib/api/schema.ts",
    "types:api:file": "openapi-typescript ../backend/openapi.json -o src/lib/api/schema.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@clerk/localizations": "4.7.0",
    "@clerk/nextjs": "7.4.2",
    "@clerk/themes": "^2.4.57",
    "@tanstack/react-hotkeys": "0.10.0",
    "@tanstack/react-query": "5.100.14",
    "@web-kits/audio": "0.1.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "katex": "0.16.45",
    "lucide-react": "1.17.0",
    "mafs": "0.21.0",
    "mathjs": "15.2.0",
    "motion": "12.40.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "openapi-fetch": "0.17.0",
    "posthog-js": "1.376.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "3.8.1",
    "shadcn": "4.8.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/katex": "0.16.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "patchedDependencies": {
    "@web-kits/audio@0.1.0": "patches/@web-kits%2Faudio@0.1.0.patch"
  }
}
