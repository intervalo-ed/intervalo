{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  // Exclude dep-repos from search, file watching, and auto-import suggestions
  "typescript.preferences.autoImportFileExcludePatterns": ["dep-repos/**"],
  "javascript.preferences.autoImportFileExcludePatterns": ["dep-repos/**"],
  "files.watcherExclude": {
    "dep-repos/**": true
  },
  "search.exclude": {
    "dep-repos/**": true
  }
}
