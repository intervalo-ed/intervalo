# ── Backend environment variables ────────────────────────────────────────────
# Copy to `.env` and fill in real values.

# Database — defaults to a local SQLite file if unset.
# For Postgres: postgresql://user:password@host:5432/dbname
# (Railway's legacy `postgres://` scheme is normalized automatically.)
DATABASE_URL=sqlite:///./intervalo.db

# CORS — comma-separated list of origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:3000

# ── Clerk ────────────────────────────────────────────────────────────────────
# Find these in your Clerk dashboard → API Keys → "Show JWT public key" / "Show API URLs".
# The backend verifies Clerk session JWTs against the JWKS endpoint (RS256).

# JWKS URL — used to fetch and cache Clerk's public signing keys.
# e.g. https://clean-beagle-42.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# Issuer — the `iss` claim on Clerk-issued session tokens. Must match exactly.
# e.g. https://clean-beagle-42.clerk.accounts.dev
CLERK_ISSUER=

# Audience — only set this if you use a custom session template that emits `aud`.
# Leave empty to skip the `aud` check (Clerk's default templates don't include it).
# CLERK_AUDIENCE=

# Backend API secret key — optional. Only needed if your session JWT template
# doesn't expose `email` / `name` on the token, in which case we'll fetch them
# from api.clerk.com on first sight of a new user.
# e.g. sk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=
