              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/user/enroll": {
      "post": {
        "summary": "Enroll User",
        "description": "Enroll user in a course with onboarding data.",
        "operationId": "enroll_user_user_enroll_post",
