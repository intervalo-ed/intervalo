{
  "openapi": "3.1.0",
  "info": {
    "title": "Intervalo Backend",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/course/{course_id}/belts": {
      "get": {
        "summary": "Get Belt Info",
        "description": "Returns descriptive info (headline + description) for each belt in a course.",
        "operationId": "get_belt_info_course__course_id__belts_get",
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Course Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/BeltEntry"
                  },
                  "title": "Response Get Belt Info Course  Course Id  Belts Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/guest": {
      "post": {
        "summary": "Auth Guest",
        "description": "Create anonymous guest user and return JWT.",
        "operationId": "auth_guest_auth_guest_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GuestRequest"
              }
