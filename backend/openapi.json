  "components": {
    "schemas": {
      "AnswerRequest": {
        "properties": {
          "session_id": {
            "type": "string",
            "title": "Session Id"
          },
          "exercise_id": {
            "type": "string",
            "title": "Exercise Id"
          },
          "answer_index": {
            "type": "integer",
            "title": "Answer Index"
          },
          "attempts": {
            "type": "integer",
            "title": "Attempts"
          },
          "response_time_s": {
            "type": "number",
            "title": "Response Time S"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "exercise_id",
          "answer_index",
          "attempts",
          "response_time_s"
        ],
        "title": "AnswerRequest"
      },
      "BeltEntry": {
        "properties": {
          "headline": {
            "type": "string",
            "title": "Headline"
          },
          "description": {
            "type": "string",
            "title": "Description"
          }
        },
        "type": "object",
        "required": [
          "headline",
          "description"
        ],
        "title": "BeltEntry"
      },
      "BeltProgressInfo": {
        "properties": {
          "mastered": {
            "type": "integer",
            "title": "Mastered"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "promoted": {
            "type": "boolean",
            "title": "Promoted"
          }
        },
        "type": "object",
        "required": [
          "mastered",
          "total",
          "promoted"
        ],
        "title": "BeltProgressInfo"
      },
      "DueNotification": {
        "properties": {
          "user_id": {
            "type": "integer",
            "title": "User Id"
          },
          "pending_count": {
            "type": "integer",
            "title": "Pending Count"
          },
          "subscriptions": {
            "items": {
              "$ref": "#/components/schemas/PushSubscriptionOut"
            },
            "type": "array",
            "title": "Subscriptions"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "pending_count",
          "subscriptions"
        ],
        "title": "DueNotification"
      },
      "EnrollmentRequest": {
        "properties": {
          "university": {
            "type": "string",
            "title": "University"
          },
          "career": {
            "type": "string",
            "title": "Career"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "university",
          "career"
        ],
        "title": "EnrollmentRequest"
      },
      "EnrollmentResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "title": "EnrollmentResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "LeaderboardEntry": {
        "properties": {
          "rank": {
            "type": "integer",
            "title": "Rank"
          },
          "user_id": {
            "type": "integer",
            "title": "User Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Username"
          },
          "total_xp": {
            "type": "integer",
            "title": "Total Xp"
          },
          "is_current_user": {
            "type": "boolean",
            "title": "Is Current User"
          },
          "career": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Career"
          },
          "university": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "University"
          }
        },
        "type": "object",
        "required": [
          "rank",
          "user_id",
          "name",
          "total_xp",
          "is_current_user"
        ],
        "title": "LeaderboardEntry"
      },
      "LeaderboardResponse": {
        "properties": {
          "entries": {
            "items": {
              "$ref": "#/components/schemas/LeaderboardEntry"
            },
            "type": "array",
            "title": "Entries"
          },
          "total_xp": {
            "type": "integer",
            "title": "Total Xp"
          },
