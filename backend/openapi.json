          },
          "answer_index": {
            "type": "integer",
            "title": "Answer Index"
          },
          "response_time_s": {
            "type": "number",
            "title": "Response Time S"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "exercise_id",
          "answer_index",
          "response_time_s"
